# when2run configuration (all optional)

# Port the server listens on
PORT=3000

# --- Strava integration (optional) ---
# Without these, users can still PASTE a Strava route/activity/segment link and
# it will render as an interactive embedded map. With these set, users can also
# one-click "Connect Strava" and import their own saved routes.
#
# Create an app at https://www.strava.com/settings/api
#   Authorization Callback Domain: your deploy domain (e.g. when2run.example.com)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
